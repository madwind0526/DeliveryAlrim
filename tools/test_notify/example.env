# Copy this file to ".env" in the same folder and fill in real values.
# ".env" is gitignored at the repo root (patterns ".env" / ".env.*") — never commit it.

# --- Email (Gmail SMTP relay, used for both Gmail and Naver recipients) ---
# The sender Gmail account. Enable 2-Step Verification on this account, then
# create an "App password" (Google Account > Security > 2-Step Verification >
# App passwords) — use that 16-character password below, not your normal login.
SENDER_GMAIL_ADDRESS=your-sender@gmail.com
SENDER_GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Recipient addresses to test against (the accounts the app will monitor).
RECIPIENT_GMAIL=monitored-account@gmail.com
RECIPIENT_NAVER=monitored-account@naver.com

# --- SMS (Naver Cloud Platform SENS) ---
# Console: https://console.ncloud.com > Simple & Easy Notification Service > SMS
# 1) Create a SENS project, note its Service ID (looks like ncp:sms:kr:...:project-name).
# 2) Register a sender phone number under that project. This requires phone
#    ownership verification and can take time to approve.
# 3) Create an API key pair under My Page > Account Management > Authentication Key.
NCP_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
NCP_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NCP_SENS_SERVICE_ID=ncp:sms:kr:0000000:your-project
NCP_SENS_SENDER_PHONE=01000000000
RECIPIENT_PHONE=01000000000
