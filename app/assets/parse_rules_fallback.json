{
  "rulesVersion": 1,
  "rules": [
    {
      "id": "coupang_delivered",
      "sourceTypes": ["mall_app", "kakao", "sms"],
      "bodyRegex": "\\[쿠팡\\][^\\n]*배송했습니다",
      "courierCode": "coupang_direct",
      "statusHint": "delivered",
      "priority": 10
    },
    {
      "id": "coupang_out_for_delivery",
      "sourceTypes": ["mall_app", "kakao", "sms"],
      "bodyRegex": "\\[쿠팡\\][^\\n]*배송\\s*시작",
      "courierCode": "coupang_direct",
      "statusHint": "out_for_delivery",
      "priority": 11
    },
    {
      "id": "coupang_app_order_complete",
      "sourceTypes": ["mall_app"],
      "packageName": "com.coupang.mobile",
      "bodyRegex": "주문이 완료되었습니다",
      "productRegex": "^(?<product>.+?)(?:\\s*외\\s*\\d+건)?\\s*주문이 완료",
      "courierCode": "coupang_direct",
      "statusHint": "registered",
      "priority": 12
    },
    {
      "id": "labeled_invoice_generic",
      "sourceTypes": ["sms", "kakao", "gmail", "mall_app"],
      "bodyRegex": "(?:운송장|송장|등기)\\s*번호\\s*[:：]?\\s*(?<invoice>\\d[\\d\\-]{8,15}\\d)",
      "priority": 50
    },
    {
      "id": "card_order_bracket_tag",
      "sourceTypes": ["sms", "kakao", "gmail"],
      "bodyRegex": "\\[[^\\]]*카드\\][\\s\\S]*?(?<amount>\\d{1,3}(?:,\\d{3})+|\\d+)\\s*원",
      "courierCode": "card_order",
      "statusHint": "registered",
      "priority": 51
    },
    {
      "id": "card_order_generic",
      "sourceTypes": ["sms", "kakao", "gmail"],
      "titleMatch": "카드\\s*$",
      "bodyRegex": "(?<amount>\\d{1,3}(?:,\\d{3})+|\\d+)\\s*원",
      "courierCode": "card_order",
      "statusHint": "registered",
      "priority": 52
    },
    {
      "id": "mall_order_complete_generic",
      "sourceTypes": ["sms", "kakao", "gmail"],
      "bodyRegex": "\\[(?<mall>[^\\]]+)\\][\\s\\S]{0,30}?주문\\s*완료[\\s\\S]*?주문번호\\s*[:：]?\\s*(?<orderNo>[A-Za-z0-9\\-]{6,30})[\\s\\S]*?(?<amount>\\d{1,3}(?:,\\d{3})+|\\d+)\\s*원",
      "courierCode": "mall_order",
      "statusHint": "registered",
      "priority": 55
    }
  ]
}
